# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to git

# Database Configuration
MySQL_HOST=your-mysql-host
MySQL_USER=your-mysql-user
MySQL_PASS=your-mysql-password
MySQL_DB=your-database-name
MySQL_PORT=3306

# API Keys
P_API_KEY=your-api-key

# Email Configuration
EMAIL_USERNAME=your-email@example.com
EMAIL_PWD=your-email-password
EMAIL_PAGOS_USER=pagos@example.com
EMAIL_PAGOS_PWD=pagos-password
EMAIL_SMTP=smtp.gmail.com

# Auth0 Configuration
AUTH0_USER=your-auth0-user
AUTH0_KEY=your-auth0-key
AUTH0_SECRET=your-auth0-secret

# LLM API
LLM_API=your-llm-api-key

# Environment (local development uses 'default', production uses 'prod')
R_CONFIG_ACTIVE=prod
